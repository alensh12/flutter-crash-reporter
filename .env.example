# Copy into Vercel project settings or a local `.env` file for `vercel dev`.
CRASH_REPORTER_API_KEY=replace-with-a-long-random-secret

# Supabase (persistent crash storage). Create a project at https://supabase.com
# then run supabase/schema.sql in the SQL editor.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
